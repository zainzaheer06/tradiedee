{"docstore/metadata": {"0ca44cb7-d047-4d73-ac2c-7e9a222f0168": {"doc_hash": "c9a95153566a835ed00ec2b2356ae854de062814d591c1007f0db60e0a0ca32a"}, "eee245bd-98ce-47e1-b3e6-73fcc9151f17": {"doc_hash": "77bf233de446f694839d36c4e3661fe4428cea2c8c2584ce78895c328505a864", "ref_doc_id": "0ca44cb7-d047-4d73-ac2c-7e9a222f0168"}}, "docstore/ref_doc_info": {"0ca44cb7-d047-4d73-ac2c-7e9a222f0168": {"node_ids": ["eee245bd-98ce-47e1-b3e6-73fcc9151f17"], "metadata": {"file_path": "C:\\Users\\mzain\\Python-projects\\Commercial\\nevox-livekit\\knowledge_bases\\agent_16\\docs\\demo_knowledge_base.txt", "file_name": "demo_knowledge_base.txt", "file_type": "text/plain", "file_size": 2520, "creation_date": "2025-11-16", "last_modified_date": "2025-11-16"}}}, "docstore/data": {"eee245bd-98ce-47e1-b3e6-73fcc9151f17": {"__data__": {"id_": "eee245bd-98ce-47e1-b3e6-73fcc9151f17", "embedding": null, "metadata": {"file_path": "C:\\Users\\mzain\\Python-projects\\Commercial\\nevox-livekit\\knowledge_bases\\agent_16\\docs\\demo_knowledge_base.txt", "file_name": "demo_knowledge_base.txt", "file_type": "text/plain", "file_size": 2520, "creation_date": "2025-11-16", "last_modified_date": "2025-11-16"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "0ca44cb7-d047-4d73-ac2c-7e9a222f0168", "node_type": "4", "metadata": {"file_path": "C:\\Users\\mzain\\Python-projects\\Commercial\\nevox-livekit\\knowledge_bases\\agent_16\\docs\\demo_knowledge_base.txt", "file_name": "demo_knowledge_base.txt", "file_type": "text/plain", "file_size": 2520, "creation_date": "2025-11-16", "last_modified_date": "2025-11-16"}, "hash": "c9a95153566a835ed00ec2b2356ae854de062814d591c1007f0db60e0a0ca32a", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0639\u0646 \u0634\u0631\u0643\u0629 \u0646\u064a\u0641\u0648\u0643\u0633 \u0644\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a\n==========================================\n\n\u0646\u0638\u0631\u0629 \u0639\u0627\u0645\u0629:\n\u0646\u064a\u0641\u0648\u0643\u0633 \u0647\u064a \u0634\u0631\u0643\u0629 \u0631\u0627\u0626\u062f\u0629 \u0641\u064a \u0645\u062c\u0627\u0644 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0627\u0644\u0635\u0648\u062a\u064a\u060c \u0645\u062a\u062e\u0635\u0635\u0629 \u0641\u064a \u0628\u0646\u0627\u0621 \u0648\u0643\u0644\u0627\u0621 \u0635\u0648\u062a\u064a\u064a\u0646 \u0623\u0630\u0643\u064a\u0627\u0621 \u0644\u0644\u0634\u0631\u0643\u0627\u062a \u0641\u064a \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629.\n\n\u0627\u0644\u062e\u062f\u0645\u0627\u062a:\n1. \u0648\u0643\u0644\u0627\u0621 \u0635\u0648\u062a\u064a\u0648\u0646 \u0644\u0644\u0645\u0643\u0627\u0644\u0645\u0627\u062a \u0627\u0644\u0648\u0627\u0631\u062f\u0629\n   - \u0627\u0644\u0631\u062f \u0627\u0644\u062a\u0644\u0642\u0627\u0626\u064a \u0639\u0644\u0649 \u0627\u0644\u0645\u0643\u0627\u0644\u0645\u0627\u062a\n   - \u062f\u0639\u0645 \u0627\u0644\u0644\u063a\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0628\u0634\u0643\u0644 \u0643\u0627\u0645\u0644\n   - \u062a\u062e\u0635\u064a\u0635 \u0627\u0644\u0635\u0648\u062a \u0648\u0627\u0644\u0634\u062e\u0635\u064a\u0629\n\n2. \u062d\u0645\u0644\u0627\u062a \u0627\u0644\u0627\u062a\u0635\u0627\u0644 \u0627\u0644\u0635\u0627\u062f\u0631\u0629\n   - \u0625\u062c\u0631\u0627\u0621 \u0645\u0643\u0627\u0644\u0645\u0627\u062a \u062c\u0645\u0627\u0639\u064a\u0629 \u0622\u0644\u064a\u0629\n   - \u062a\u062a\u0628\u0639 \u0627\u0644\u0646\u062a\u0627\u0626\u062c \u0648\u0627\u0644\u0627\u0647\u062a\u0645\u0627\u0645\n   - \u062c\u062f\u0648\u0644\u0629 \u0627\u0644\u0645\u0643\u0627\u0644\u0645\u0627\u062a\n\n3. \u0642\u0627\u0639\u062f\u0629 \u0627\u0644\u0645\u0639\u0631\u0641\u0629 (RAG)\n   - \u0631\u0641\u0639 \u0627\u0644\u0645\u0633\u062a\u0646\u062f\u0627\u062a \u0648\u0627\u0644\u0623\u062f\u0644\u0629\n   - \u0627\u0644\u0628\u062d\u062b \u0627\u0644\u0630\u0643\u064a \u0639\u0646 \u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062a\n   - \u0625\u062c\u0627\u0628\u0627\u062a \u062f\u0642\u064a\u0642\u0629 \u0628\u0646\u0627\u0621\u064b \u0639\u0644\u0649 \u0628\u064a\u0627\u0646\u0627\u062a\u0643\n\n\u0633\u0627\u0639\u0627\u062a \u0627\u0644\u0639\u0645\u0644:\n\u0627\u0644\u0623\u062d\u062f \u0625\u0644\u0649 \u0627\u0644\u062e\u0645\u064a\u0633: 9:00 \u0635\u0628\u0627\u062d\u0627\u064b - 6:00 \u0645\u0633\u0627\u0621\u064b\n\u0627\u0644\u062c\u0645\u0639\u0629 \u0648\u0627\u0644\u0633\u0628\u062a: \u0645\u063a\u0644\u0642\n\n\u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0627\u0644\u0627\u062a\u0635\u0627\u0644:\n\u0627\u0644\u0628\u0631\u064a\u062f \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a: support@nevox.ai\n\u0627\u0644\u0645\u0648\u0642\u0639 \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a: www.nevox.ai\n\n\u0627\u0644\u0623\u0633\u0626\u0644\u0629 \u0627\u0644\u0634\u0627\u0626\u0639\u0629:\n\n\u0633: \u0647\u0644 \u064a\u062f\u0639\u0645 \u0627\u0644\u0646\u0638\u0627\u0645 \u0627\u0644\u0644\u063a\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629\u061f\n\u062c: \u0646\u0639\u0645\u060c \u0646\u064a\u0641\u0648\u0643\u0633 \u0645\u0635\u0645\u0645 \u062e\u0635\u064a\u0635\u0627\u064b \u0644\u0644\u063a\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0645\u0639 \u062f\u0639\u0645 \u0643\u0627\u0645\u0644 \u0644\u0644\u0644\u0647\u062c\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629.\n\n\u0633: \u0643\u0645 \u0639\u062f\u062f \u0627\u0644\u0645\u0643\u0627\u0644\u0645\u0627\u062a \u0627\u0644\u0645\u062a\u0632\u0627\u0645\u0646\u0629 \u0627\u0644\u0645\u062f\u0639\u0648\u0645\u0629\u061f\n\u062c: \u064a\u062f\u0639\u0645 \u0627\u0644\u0646\u0638\u0627\u0645 \u062d\u062a\u0649 50 \u0645\u0643\u0627\u0644\u0645\u0629 \u0645\u062a\u0632\u0627\u0645\u0646\u0629 \u0641\u064a \u0627\u0644\u062d\u0645\u0644\u0629 \u0627\u0644\u0648\u0627\u062d\u062f\u0629.\n\n\u0633: \u0647\u0644 \u064a\u0645\u0643\u0646 \u062a\u062e\u0635\u064a\u0635 \u0635\u0648\u062a \u0627\u0644\u0648\u0643\u064a\u0644\u061f\n\u062c: \u0646\u0639\u0645\u060c \u064a\u0645\u0643\u0646\u0643 \u0627\u062e\u062a\u064a\u0627\u0631 \u0645\u0646 \u0628\u064a\u0646 5 \u0623\u0635\u0648\u0627\u062a \u0639\u0631\u0628\u064a\u0629 \u0645\u062e\u062a\u0644\u0641\u0629 \u0648\u062a\u062e\u0635\u064a\u0635 \u0627\u0644\u062a\u0631\u062d\u064a\u0628 \u0648\u0627\u0644\u062a\u0639\u0644\u064a\u0645\u0627\u062a.\n\n\u0633: \u0643\u064a\u0641 \u064a\u062a\u0645 \u062a\u062a\u0628\u0639 \u0627\u0644\u0627\u0647\u062a\u0645\u0627\u0645 \u0641\u064a \u0627\u0644\u062d\u0645\u0644\u0627\u062a\u061f\n\u062c: \u064a\u0633\u062a\u062e\u062f\u0645 \u0627\u0644\u0646\u0638\u0627\u0645 \u062a\u062d\u0644\u064a\u0644 \u0627\u0644\u0645\u0634\u0627\u0639\u0631 \u0627\u0644\u0645\u062a\u0642\u062f\u0645 \u0644\u062a\u062d\u062f\u064a\u062f \u0645\u0633\u062a\u0648\u0649 \u0627\u0647\u062a\u0645\u0627\u0645 \u0627\u0644\u0639\u0645\u064a\u0644 \u062a\u0644\u0642\u0627\u0626\u064a\u0627\u064b.\n\n\u0627\u0644\u0645\u0632\u0627\u064a\u0627 \u0627\u0644\u0631\u0626\u064a\u0633\u064a\u0629:\n- \u0633\u0631\u0639\u0629 \u0627\u0633\u062a\u062c\u0627\u0628\u0629 \u0639\u0627\u0644\u064a\u0629 (\u0623\u0642\u0644 \u0645\u0646 500 \u0645\u0644\u0644\u064a \u062b\u0627\u0646\u064a\u0629)\n- \u062f\u0642\u0629 \u0639\u0627\u0644\u064a\u0629 \u0641\u064a \u0627\u0644\u062a\u0639\u0631\u0641 \u0639\u0644\u0649 \u0627\u0644\u0643\u0644\u0627\u0645 \u0627\u0644\u0639\u0631\u0628\u064a\n- \u062a\u0643\u0627\u0645\u0644 \u0633\u0647\u0644 \u0645\u0639 \u0627\u0644\u0623\u0646\u0638\u0645\u0629 \u0627\u0644\u0645\u0648\u062c\u0648\u062f\u0629\n- \u0644\u0648\u062d\u0629 \u062a\u062d\u0643\u0645 \u0634\u0627\u0645\u0644\u0629 \u0644\u0644\u0645\u0631\u0627\u0642\u0628\u0629 \u0648\u0627\u0644\u062a\u062d\u0644\u064a\u0644\n- \u0623\u0645\u0627\u0646 \u0648\u062e\u0635\u0648\u0635\u064a\u0629 \u0639\u0627\u0644\u064a\u0629 \u0644\u0644\u0628\u064a\u0627\u0646\u0627\u062a\n\n\u0627\u0644\u0623\u0633\u0639\u0627\u0631:\n\u064a\u0631\u062c\u0649 \u0627\u0644\u0627\u062a\u0635\u0627\u0644 \u0628\u0641\u0631\u064a\u0642 \u0627\u0644\u0645\u0628\u064a\u0639\u0627\u062a \u0644\u0644\u062d\u0635\u0648\u0644 \u0639\u0644\u0649 \u0639\u0631\u0636 \u0645\u062e\u0635\u0635 \u0628\u0646\u0627\u0621\u064b \u0639\u0644\u0649 \u0627\u062d\u062a\u064a\u0627\u062c\u0627\u062a\u0643.", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 1461, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}}}