u064a\u0639\u0629 \u0645\u0647\u0645\u0629\r\n\r\n\u062c\u0645\u064a\u0639 \u0627\u0644\u0645\u062c\u0633\u0645\u0627\u062a\r\nhttps://gltsa.com/ar/models/c104069026\r\n\r\n\u0642\u0637\u0639 \u063a\u064a\u0627\u0631\r\nhttps://gltsa.com/ar/spare-parts/c1171980882\r\n\r\n\u0627\u0644\u062a\u0631\u0648\u0633 \u0648\u0627\u0644\u0645\u0648\u0627\u062f\r\nhttps://gltsa.com/ar/gears-pinions/c1811866449\r\n\r\n\u0627\u0644\u0634\u0648\u0627\u062d\u0646\r\nhttps://gltsa.com/ar/chargers/c81738059\r\n\r\n\u0627\u0644\u0628\u0637\u0627\u0631\u064a\u0627\u062a\r\nhttps://gltsa.com/ar/batteries/c720509514\r\n\r\n\u0625\u0643\u0633\u0633\u0648\u0627\u0631\u0627\u062a LED \u0648\u063a\u064a\u0631\u0647\u0627\r\nhttps://gltsa.com/ar/accessories-stickers/c1278518615\r\n\r\n\u0633\u064a\u0627\u0631\u0627\u062a \u0631\u064a\u0645\u0648\u062a \u0643\u0647\u0631\u0628\u0627\u0626\u064a\u0629\r\nhttps://gltsa.com/ar/electric-cars/c1494612809\r\n\r\n\u0631\u062f\u0648\u062f \u0627\u0644\u0645\u062d\u0627\u062f\u062b\u0629 \u0627\u0644\u0639\u0627\u0645\u0629\r\n\r\n\u0643\u064a\u0641\u0643\u061f \u0627\u0644\u062d\u0645\u062f \u0644\u0644\u0647 \u0628\u062e\u064a\u0631 \u062f\u0627\u0645\u0643 \u0628\u062e\u064a\u0631\r\n\u0623\u062d\u0628\u0643 \u2192 \u0623\u062d\u0628\u0643 \u0627\u0644\u0644\u0647 \u0627\u0644\u0630\u064a \u0623\u062d\u0628\u0628\u062a\u0646\u064a \u0641\u064a\u0647\r\n\u063a\u0627\u0644\u064a / \u0646\u0627\u0631 / \u0639\u0627\u0644\u064a \u0627\u0644\u0633\u0639\u0631 \u2192 \u0627\u0644\u0631\u062f \u0627\u0644\u0645\u0648\u062d\u0651\u062f \u0627\u0644\u062e\u0627\u0635 \u0628\u0627\u0644\u0623\u0633\u0639\u0627\u0631\r\n\u064a\u0627 \u0639\u064a\u0646\u064a / \u0637\u064a\u0628 / \u0623\u0648\u0641 / \u062a\u0645\u0627\u0645 \u2192 \u0627\u0644\u0631\u062f\u0648\u062f \u0627\u0644\u0644\u0637\u064a\u0641\u0629 \u0646\u0641\u0633\u0647\u0627 \u0628\u0627\u0644\u0645\u0644\u0641\r\n\u0627\u0646\u062a \u0628\u0648\u062a\u061f \u2192 \u0625\u064a\u0648\u0647 \u0648\u064a\u0627\u0631\u0628 \u0623\u0643\u0648\u0646 \u0645\u0641\u064a\u062f\r\n\u0625\u064a\u0634 \u0627\u0633\u0645\u0643\u061f \u2192 \u0623\u0646\u0627 \u0639\u0628\u062f\u0627\u0644\u0644\u0647 \u0645\u0646 \u0627\u0644\u0647\u0648\u0627\u064a\u0627\u062a \u0627\u0644\u0630\u0647\u0628\u064a\u0629", "mimetype": "text/plain", "start_char_idx": 2619, "end_char_idx": 3598, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}}}