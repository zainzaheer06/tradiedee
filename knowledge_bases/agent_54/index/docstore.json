pe": "4", "metadata": {"file_path": "C:\\Users\\mzain\\Python-projects\\Commercial\\nevoxai_server\\nevoxai-project\\knowledge_bases\\agent_54\\docs\\AI_Training_-_Copy.txt", "file_name": "AI_Training_-_Copy.txt", "file_type": "text/plain", "file_size": 5686, "creation_date": "2026-01-11", "last_modified_date": "2026-01-11"}, "hash": "16fc0db5db51d129b3029b44ccdfe3f86fea045d026f924a53cd14bd1669ebf2", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "4abbabb2-2467-4003-800a-6a4ef21db5d2", "node_type": "1", "metadata": {}, "hash": "4b3640dfa5e099dd34bb9abc26f572a5b524584bb14f27d217aa744d641f3fff", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u062a\u0646\u0628\u064a\u0647 \u0639\u0627\u0645\r\n\r\n\u0627\u0633\u062a\u062e\u062f\u0645 \u0623\u0633\u0644\u0648\u0628 \u0644\u0637\u064a\u0641 \u0628\u0644\u0627 \u0639\u0644\u0627\u0645\u0627\u062a \u062a\u0639\u062c\u0628 \u0645\u0639 \u0627\u0644\u0639\u0645\u0644\u0627\u0621.\r\n\u0625\u0630\u0627 \u0644\u0645 \u062a\u0639\u0631\u0641 \u0627\u0644\u0631\u062f \u0627\u0644\u0645\u0646\u0627\u0633\u0628: \u0623\u0639\u0637\u0650 \u0627\u0644\u0639\u0645\u064a\u0644 \u0631\u0642\u0645 \u0627\u0644\u062a\u0648\u0627\u0635\u0644 +966503685820\r\n\u062f\u0648\u0627\u0645 \u062e\u062f\u0645\u0629 \u0627\u0644\u0639\u0645\u0644\u0627\u0621: \u0627\u0644\u0623\u062d\u062f\u2013\u0627\u0644\u062e\u0645\u064a\u0633 \u0645\u0646 5\u0645 \u0625\u0644\u0649 9\u0645\r\n\r\n\u0627\u0644\u062a\u062d\u064a\u0627\u062a \u0648\u0627\u0644\u0631\u062f\u0648\u062f \u0627\u0644\u0623\u0633\u0627\u0633\u064a\u0629\r\n\r\n\u0627\u0644\u0633\u0644\u0627\u0645 \u0639\u0644\u064a\u0643\u0645 \u2192 \u0648\u0639\u0644\u064a\u0643\u0645 \u0627\u0644\u0633\u0644\u0627\u0645 \u0648\u0631\u062d\u0645\u0629 \u0627\u0644\u0644\u0647 \u0648\u0628\u0631\u0643\u0627\u062a\u0647\u060c \u0623\u0647\u0644\u0627\u064b \u0628\u0643\u2026 (\u062b\u0645 \u0631\u0627\u0628\u0637 \u0627\u0644\u0645\u062a\u062c\u0631)\r\n\u0645\u0631\u062d\u0628\u0627 / \u0647\u0644\u0627 \u2192 \u0623\u0647\u0644\u0627\u064b \u0628\u0643\u2026 (\u062b\u0645 \u0631\u0627\u0628\u0637 \u0627\u0644\u0645\u062a\u062c\u0631)\r\n\r\n\u0631\u0627\u0628\u0637 \u0627\u0644\u0645\u062a\u062c\u0631:\r\nhttps://gltsa.com\r\n\r\n\u0623\u0633\u0626\u0644\u0629 \u0627\u0644\u062a\u0639\u0631\u064a\u0641\r\n\r\n\u0645\u0627 \u0647\u0648 \u0645\u062a\u062c\u0631 \u0627\u0644\u0647\u0648\u0627\u064a\u0627\u062a \u0627\u0644\u0630\u0647\u0628\u064a\u0629\u061f\r\n\u0645\u062a\u062c\u0631 \u0645\u062a\u062e\u0635\u0635 \u0641\u064a \u0627\u0644\u0645\u062c\u0633\u0645\u0627\u062a \u0627\u0644\u0627\u062d\u062a\u0631\u0627\u0641\u064a\u0629 \u0630\u0627\u062a \u0627\u0644\u062a\u0641\u0627\u0635\u064a\u0644 \u0627\u0644\u0639\u0627\u0644\u064a\u0629 \u0648\u0627\u0644\u0625\u0646\u062a\u0627\u062c \u0627\u0644\u0645\u062d\u062f\u0648\u062f \u0645\u0646 \u0634\u0631\u0643\u0627\u062a \u0639\u0627\u0644\u0645\u064a\u0629 \u0645\u0639\u0631\u0648\u0641\u0629.\r\n\r\n\u0625\u064a\u0634 \u062a\u0628\u064a\u0639\u0648\u0646 / \u0625\u064a\u0634 \u0639\u0646\u062f\u0643\u0645\u061f\r\n\u0645\u062c\u0633\u0645\u0627\u062a \u0633\u064a\u0627\u0631\u0627\u062a \u0627\u062d\u062a\u0631\u0627\u0641\u064a\u0629 \u0628\u0625\u0635\u062f\u0627\u0631 \u0645\u062d\u062f\u0648\u062f \u0645\u0646 \u0645\u0627\u0631\u0643\u0627\u062a \u0639\u0627\u0644\u0645\u064a\u0629. (\u0645\u0639 \u0631\u0627\u0628\u0637 \u0642\u0633\u0645 \u0627\u0644\u0645\u062c\u0633\u0645\u0627\u062a)\r\n\r\n\u0627\u0644\u0645\u0648\u0642\u0639\r\n\r\n\u0648\u064a\u0646 \u064a\u0642\u0639 \u0627\u0644\u0645\u062a\u062c\u0631\u061f\r\n\u0627\u0644\u0645\u0639\u0631\u0636 \u0641\u064a \u062c\u062f\u0629 \u2014 \u062d\u064a \u0627\u0644\u0633\u0644\u0627\u0645\u0629 \u2014 \u0645\u0646\u0630 22 \u0639\u0627\u0645\u0627\u064b.\r\n\u0627\u0644\u0632\u064a\u0627\u0631\u0629: 5\u20139 \u0645\u0633\u0627\u0621\u064b (\u0627\u0644\u0623\u062d\u062f\u2013\u0627\u0644\u062e\u0645\u064a\u0633)\r\n\u0627\u0644\u0645\u0648\u0642\u0639:\r\nhttps://maps.app.goo.gl/EM4vaEDJyw9vVK787\r\n\r\n\u0647\u0644 \u0644\u062f\u064a\u0643\u0645 \u0641\u0631\u0639 \u0641\u064a \u0627\u0644\u0631\u064a\u0627\u0636 / \u0627\u0644\u0634\u0631\u0642\u064a\u0629 / \u0627\u0644\u0645\u062f\u064a\u0646\u0629\u061f\r\n\u0646\u062d\u0646 \u0641\u064a \u062c\u062f\u0629 \u0648\u0646\u0634\u062d\u0646 \u0644\u0643\u0644 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0648\u062e\u0627\u0631\u062c \u0627\u0644\u0645\u0645\u0644\u0643\u0629.\r\n\r\n\u0627\u0644\u0645\u0646\u062a\u062c\u0627\u062a\r\n\r\n\u0647\u0644 \u0627\u0644\u0645\u0646\u062a\u062c\u0627\u062a \u0623\u0635\u0644\u064a\u0629\u061f \u0646\u0639\u0645\r\n\u0647\u0644 \u0647\u064a \u062c\u062f\u064a\u062f\u0629\u061f \u0646\u0639\u0645 \u0645\u0627 \u0644\u0645 \u064a\u0643\u062a\u0628 PRE-OWNED\r\n\u0647\u0644 \u0647\u064a \u0645\u062d\u062f\u0648\u062f\u0629\u061f \u0623\u063a\u0644\u0628\u0647\u0627 \u0645\u062d\u062f\u0648\u062f\u0629 \u0648\u0645\u0643\u062a\u0648\u0628 \u0627\u0644\u0639\u062f\u062f \u0628\u0627\u0644\u0645\u0646\u062a\u062c\r\n\r\n\u0627\u0644\u0645\u0642\u0627\u0633\u0627\u062a\u061f\r\n1:18 \u0642\u0631\u064a\u0628 \u0645\u0646 \u0639\u0644\u0628\u0629 \u0645\u0646\u0627\u062f\u064a\u0644\r\n1:43 \u0642\u0631\u064a\u0628 \u0645\u0646 \u0627\u0644\u0623\u0635\u0628\u0639\r\n1:64 \u0623\u0635\u063a\u0631 \u0645\u0646 \u0627\u0644\u0623\u0635\u0628\u0639\r\n\u0641\u064a\u062f\u064a\u0648 \u0644\u0644\u062a\u0648\u0636\u064a\u062d:\r\nhttps://youtu.be/hzf-T0lTpJE\r\n\r\n\u0647\u0644 \u0639\u0646\u062f\u0643\u0645 \u0643\u0644\u0627\u0633\u064a\u0643\u061f \u0646\u0639\u0645 (\u0645\u062b\u0644 Toyota)\r\n\u062d\u062f\u064a\u062b\u0629\u061f \u0646\u0639\u0645 (\u0645\u062b\u0644 Ferrari)\r\n\u064a\u0627\u0628\u0627\u0646\u064a/\u0623\u0648\u0631\u0648\u0628\u064a/\u0623\u0645\u0631\u064a\u0643\u064a\u061f \u0646\u0639\u0645 (\u0645\u062b\u0644 Porsche)\r\n\u0634\u0627\u062d\u0646\u0627\u062a/\u062f\u0631\u0627\u062c\u0627\u062a\u061f \u0623\u062d\u064a\u0627\u0646\u0627\u064b\r\n\u0637\u0627\u0626\u0631\u0627\u062a\u061f \u0646\u0639\u0645 (\u0631\u0627\u0628\u0637 1/200 \u06481/400)\r\n\r\n\u0647\u0644 \u0623\u0642\u062f\u0631 \u0623\u0641\u0635\u0644 \u0639\u0644\u0649 \u0633\u064a\u0627\u0631\u062a\u064a\u061f\r\n\u0644\u0627 \u064a\u0648\u062c\u062f \u062a\u0641\u0635\u064a\u0644 \u0639\u0627\u0644\u0645\u064a\u064b\u0627. \u0627\u0644\u0645\u062c\u0633\u0645\u0627\u062a \u0625\u0646\u062a\u0627\u062c \u062c\u0627\u0647\u0632 \u0641\u0642\u0637.", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 1349, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "4abbabb2-2467-4003-800a-6a4ef21db5d2": {"__data__": {"id_": "4abbabb2-2467-4003-800a-6a4ef21db5d2", "embedding": null, "metadata": {"file_path": "C:\\Users\\mzain\\Python-projects\\Commercial\\nevoxai_server\\nevoxai-project\\knowledge_bases\\agent_54\\docs\\AI_Training_-_Copy.txt", "file_name": "AI_Training_-_Copy.txt", "file_type": "text/plain", "file_size": 5686, "creation_date": "2026-01-11", "last_modified_date": "2026-01-11"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "01866adc-c93a-4d95-a9d3-80c7ecbab04a", "node_type": "4", "metadata": {"file_path": "C:\\Users\\mzain\\Python-projects\\Commercial\\nevoxai_server\\nevoxai-project\\knowledge_bases\\agent_54\\docs\\AI_Training_-_Copy.txt", "file_name": "AI_Training_-_Copy.txt", "file_type": "text/plain", "file_size": 5686, "creation_date": "2026-01-11", "last_modified_date": "2026-01-11"}, "hash": "16fc0db5db51d129b3029b44ccdfe3f86fea045d026f924a53cd14bd1669ebf2", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "127de6f4-bde7-415f-8d5a-9e8d996c19f0", "node_type": "1", "metadata": {"file_path": "C:\\Users\\mzain\\Python-projects\\Commercial\\nevoxai_server\\nevoxai-project\\knowledge_bases\\agent_54\\docs\\AI_Training_-_Copy.txt", "file_name": "AI_Training_-_Copy.txt", "file_type": "text/plain", "file_size": 5686, "creation_date": "2026-01-11", "last_modified_date": "2026-01-11"}, "hash": "bca0fd808579426496a769f0684a25ebb190ba0bdf780cb00e901b312eca2ac0", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "25560113-7f17-4a38-b9e7-f74d952df5c7", "node_type": "1", "metadata": {}, "hash": "18c13932315f81ab76a6f0b6e018c427927085a108cb875a431b55e079791908", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u0627\u0644\u0645\u062c\u0633\u0645\u0627\u062a \u0625\u0646\u062a\u0627\u062c \u062c\u0627\u0647\u0632 \u0641\u0642\u0637. (\u0645\u0639 \u062a\u0648\u0636\u064a\u062d \u0627\u0644\u0633\u0628\u0628)\r\n\r\n\u0647\u0644 \u0639\u0646\u062f\u0643\u0645 \u0637\u0644\u0628 \u0645\u0633\u0628\u0642\u061f\r\n\u0628\u0639\u0636 \u0627\u0644\u0645\u062c\u0633\u0645\u0627\u062a \u0627\u0644\u0646\u0627\u062f\u0631\u0629 \u0646\u0639\u0645 (\u0631\u0627\u0628\u0637 \u0627\u0644\u062c\u062f\u064a\u062f)\r\n\r\n\u0627\u0644\u0641\u0626\u0627\u062a \u062d\u0633\u0628 \u0627\u0644\u0645\u0642\u0627\u0633\r\n\r\n1:18 \u2192 https://gltsa.com/ar/scale-18/c2143442093\r\n\r\n1:43 \u2192 https://gltsa.com/ar/scale-43/c460690095\r\n\r\n1:64 \u2192 https://gltsa.com/ar/scale-64/c1968353704\r\n\r\n1:12 \u2192 https://gltsa.com/ar/scale-12/c769996204\r\n\r\n1:8 \u2192 https://gltsa.com/ar/scale-8/c1343755939\r\n\r\n\u0627\u0644\u0634\u0631\u0627\u0621 \u0648\u0627\u0644\u0637\u0644\u0628\u0627\u062a\r\n\r\n\u0643\u064a\u0641 \u0623\u0637\u0644\u0628\u061f \u0639\u0628\u0631 \u0627\u0644\u0645\u0648\u0642\u0639 \u0623\u0648 \u0648\u0627\u062a\u0633\u0627\u0628.\r\n\u0647\u0644 \u0623\u0642\u062f\u0631 \u0623\u0637\u0644\u0628 \u0645\u0646 \u0627\u0644\u0648\u0627\u062a\u0633\u0627\u0628\u061f \u0646\u0639\u0645.\r\n\u0637\u0631\u0642 \u0627\u0644\u062f\u0641\u0639\u061f \u0645\u062f\u0649\u060c \u0641\u064a\u0632\u0627\u060c \u0645\u0627\u0633\u062a\u0631\u0643\u0627\u0631\u062f\u060c \u0623\u0628\u0644 \u0628\u0627\u064a\u060c \u062a\u062d\u0648\u064a\u0644 \u0628\u0646\u0643\u064a\u060c \u0648\u062a\u0645\u0627\u0631\u0627 \u0648\u062a\u0627\u0628\u064a.\r\n\r\n\u0627\u0644\u062a\u062d\u0648\u064a\u0644 \u0627\u0644\u0628\u0646\u0643\u064a\r\n(3 \u062d\u0633\u0627\u0628\u0627\u062a \u0643\u0645\u0627 \u0641\u064a \u0627\u0644\u0645\u0644\u0641 \u0645\u0639 \u0623\u0631\u0642\u0627\u0645 \u0627\u0644\u0622\u064a\u0628\u0627\u0646)\r\n\r\n\u0641\u0627\u062a\u0648\u0631\u0629 \u0636\u0631\u064a\u0628\u064a\u0629\u061f \u0646\u0639\u0645.\r\n\u0647\u0644 \u062a\u0648\u0635\u0644\u0648\u0646 \u062f\u0627\u062e\u0644 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629\u061f \u0646\u0639\u0645.\r\n\u0645\u062f\u0629 \u0627\u0644\u062a\u0648\u0635\u064a\u0644\u061f \u062e\u0644\u0627\u0644 5 \u0623\u064a\u0627\u0645 (\u0639\u0627\u062f\u0629 \u0623\u0642\u0644).\r\n\u0627\u0644\u0634\u062d\u0646 \u0627\u0644\u062f\u0648\u0644\u064a\u061f \u0646\u0639\u0645 \u0639\u0628\u0631 DHL.\r\n\u0645\u062f\u0629 \u0627\u0644\u0634\u062d\u0646 \u0627\u0644\u062f\u0648\u0644\u064a\u061f \u062d\u062a\u0649 14 \u064a\u0648\u0645 (\u0639\u0627\u062f\u0629 \u0623\u0642\u0644).\r\n\u0647\u0644 \u064a\u0645\u0643\u0646 \u062a\u062a\u0628\u0639 \u0627\u0644\u0634\u062d\u0646\u0629\u061f \u0646\u0639\u0645.\r\n\r\n\u0633\u064a\u0627\u0633\u0629 \u0627\u0644\u0625\u0631\u062c\u0627\u0639 \u0648\u0627\u0644\u0627\u0633\u062a\u0628\u062f\u0627\u0644\r\n\r\n\u0625\u0631\u062c\u0627\u0639\u061f \u062e\u0644\u0627\u0644 24 \u0633\u0627\u0639\u0629 \u0628\u062d\u0627\u0644\u0629 \u062c\u062f\u064a\u062f\u0629.\r\n\u0627\u0633\u062a\u0628\u062f\u0627\u0644\u061f \u062e\u0644\u0627\u0644 3 \u0623\u064a\u0627\u0645.\r\n\u0627\u0633\u062a\u0631\u062f\u0627\u062f \u0627\u0644\u0645\u0628\u0644\u063a\u061f \u0628\u0639\u062f \u0627\u0633\u062a\u0644\u0627\u0645 \u0627\u0644\u0645\u0646\u062a\u062c \u0628\u0646\u0641\u0633 \u0648\u0633\u064a\u0644\u0629 \u0627\u0644\u062f\u0641\u0639.\r\n\r\n\u0627\u0644\u0623\u0633\u0639\u0627\u0631\r\n\r\n\u0644\u064a\u0634 \u0627\u0644\u0623\u0633\u0639\u0627\u0631 \u063a\u0627\u0644\u064a\u0629 / \u0646\u0627\u0631\u061f\r\n\u062a\u0639\u062a\u0645\u062f \u0639\u0644\u0649 \u0627\u0644\u062a\u0643\u0644\u0641\u0629 \u0648\u0627\u0644\u062c\u0648\u062f\u0629 \u0648\u0627\u0644\u062f\u0642\u0629 \u0648\u0627\u0644\u0643\u0645\u064a\u0629 \u0627\u0644\u0645\u0646\u062a\u062c\u0629\u2026 (\u0627\u0644\u0646\u0635 \u0643\u0645\u0627 \u0641\u064a \u0627\u0644\u0645\u0644\u0641).\r\n\r\n\u0641\u064a \u0623\u0631\u062e\u0635\u061f\r\n\u0646\u0639\u0645 (\u0631\u0627\u0628\u0637 \u0627\u0644\u0641\u0631\u0632 \u0645\u0646 \u0627\u0644\u0623\u0631\u062e\u0635).\r\n\u0623\u0631\u062e\u0635 \u0634\u0631\u0643\u0629\u061f Mini GT \u0648Maisto.\r\n\r\n\u0645\u0646\u062a\u062c\u0627\u062a \u0645\u062d\u062f\u0648\u062f\u0629 \u062c\u062f\u0627\u064b\u061f \u0631\u0627\u0628\u0637 limited.\r\n\r\n\u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0625\u0636\u0627\u0641\u064a\u0629\r\n\r\n\u062a\u063a\u0644\u064a\u0641 \u0627\u0644\u0647\u062f\u0627\u064a\u0627\u061f \u063a\u064a\u0631 \u0645\u062a\u0648\u0641\u0631\u060c \u0644\u0643\u0646 \u064a\u0648\u062c\u062f \u0643\u064a\u0633 \u0627\u0644\u0645\u062a\u062c\u0631.\r\n\u0625\u0631\u0633\u0627\u0644 \u0643\u0647\u062f\u064a\u0629\u061f \u0646\u0639\u0645.\r\n\u0647\u0644 \u062a\u0628\u064a\u0639\u0648\u0646 \u0628\u0627\u0644\u062c\u0645\u0644\u0629\u061f \u062d\u0633\u0628 \u062a\u0648\u0641\u0631 \u0627\u0644\u0625\u0646\u062a\u0627\u062c (\u0625\u064a\u0645\u064a\u0644 gm@gltsa.com\r\n).\r\n\u062a\u0639\u0627\u0648\u0646/\u062a\u0648\u0632\u064a\u0639/\u0639\u0642\u0648\u062f/\u0641\u0639\u0627\u0644\u064a\u0627\u062a\u061f \u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0639\u0628\u0631 gm@gltsa.com\r\n \u0623\u0648 \u0627\u0644\u0631\u0642\u0645.\r\n\r\n\u0627\u0644\u0645\u0634\u0627\u0643\u0644 \u0648\u0627\u0644\u0634\u062d\u0646\r\n\r\n\u0648\u0635\u0644\u0646\u064a \u0645\u0646\u062a\u062c \u062a\u0627\u0644\u0641 / \u0645\u0643\u0633\u0648\u0631\r\n\u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0645\u0639: +966503685820\r\n\r\n\u0644\u0645 \u062a\u0635\u0644 \u0627\u0644\u0634\u062d\u0646\u0629\u061f\r\n\u062a\u0648\u0627\u0635\u0644 \u0645\u0639 \u0634\u0631\u0643\u0629 \u0627\u0644\u0634\u062d\u0646 \u0623\u0648 \u0646\u0641\u0633 \u0627\u0644\u0631\u0642\u0645.\r\n\r\n\u0647\u0644 \u0627\u0644\u0634\u062d\u0646 \u0645\u0624\u0645\u0651\u0646\u061f\r\n\u064a\u0648\u0641\u0631\u0648\u0646 \u062a\u0623\u0645\u064a\u0646 \u0628\u0631\u0633\u0648\u0645 \u0625\u0636\u0627\u0641\u064a\u0629.", "mimetype": "text/plain", "start_char_idx": 1325, "end_char_idx": 2853, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "25560113-7f17-4a38-b9e7-f74d952df5c7": {"__data__": {"id_": "25560113-7f17-4a38-b9e7-f74d952df5c7", "embedding": null, "metadata": {"file_path": "C:\\Users\\mzain\\Python-projects\\Commercial\\nevoxai_server\\nevoxai-project\\knowledge_bases\\agent_54\\docs\\AI_Training_-_Copy.txt", "file_name": "AI_Training_-_Copy.txt", "file_type": "text/plain", "file_size": 5686, "creation_date": "2026-01-11", "last_modified_date": "2026-01-11"}, "excluded_embed_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "excluded_llm_metadata_keys": ["file_name", "file_type", "file_size", "creation_date", "last_modified_date", "last_accessed_date"], "relationships": {"1": {"node_id": "01866adc-c93a-4d95-a9d3-80c7ecbab04a", "node_type": "4", "metadata": {"file_path": "C:\\Users\\mzain\\Python-projects\\Commercial\\nevo