{
  "dashboard": {
    "title": "Nevox Voice Agent Analytics",
    "tags": ["voice-agent", "costs", "performance"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "💰 Total Cost Today (USD)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [{
          "expr": "sum(increase(nevox_total_cost_cents_total[24h])) / 100",
          "legendFormat": "Total Cost"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 2,
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 50, "color": "yellow"},
                {"value": 100, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "💾 Cache Savings Today (USD)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [{
          "expr": "sum(increase(nevox_cache_savings_cents_total[24h])) / 100",
          "legendFormat": "Saved"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 2,
            "color": {"mode": "fixed", "fixedColor": "green"}
          }
        }
      },
      {
        "id": 3,
        "title": "📞 Active Calls",
        "type": "gauge",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [{
          "expr": "sum(nevox_active_calls)",
          "legendFormat": "Active"
        }],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 50, "color": "yellow"},
                {"value": 80, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "📊 Cost Per Call (Avg)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [{
          "expr": "rate(nevox_total_cost_cents_total[5m]) / rate(nevox_call_duration_seconds_count[5m]) / 100",
          "legendFormat": "Avg Cost"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 4,
            "color": {"mode": "fixed", "fixedColor": "blue"}
          }
        }
      },
      {
        "id": 5,
        "title": "💸 Cost Over Time (Hourly)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "rate(nevox_total_cost_cents_total[1h]) * 36 / 100",
            "legendFormat": "Total Cost"
          },
          {
            "expr": "rate(nevox_llm_cost_cents_total[1h]) * 36 / 100",
            "legendFormat": "LLM Cost"
          },
          {
            "expr": "rate(nevox_tts_cost_cents_total[1h]) * 36 / 100",
            "legendFormat": "TTS Cost"
          }
        ],
        "yaxes": [
          {"format": "currencyUSD", "label": "Cost per Hour"},
          {"format": "short"}
        ]
      },
      {
        "id": 6,
        "title": "📈 Calls Per Minute",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [{
          "expr": "rate(nevox_call_duration_seconds_count[1m]) * 60",
          "legendFormat": "Calls/min"
        }],
        "yaxes": [
          {"format": "short", "label": "Calls"},
          {"format": "short"}
        ]
      },
      {
        "id": 7,
        "title": "🎯 Token Usage (Last Hour)",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "sum(increase(nevox_llm_prompt_tokens_total{cached=\"false\"}[1h]))",
            "legendFormat": "Uncached Prompt"
          },
          {
            "expr": "sum(increase(nevox_llm_prompt_tokens_total{cached=\"true\"}[1h]))",
            "legendFormat": "Cached Prompt"
          },
          {
            "expr": "sum(increase(nevox_llm_completion_tokens_total[1h]))",
            "legendFormat": "Completion"
          }
        ]
      },
      {
        "id": 8,
        "title": "💾 Cache Hit Rate (%)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 12},
        "targets": [{
          "expr": "sum(rate(nevox_llm_prompt_tokens_total{cached=\"true\"}[5m])) / sum(rate(nevox_llm_prompt_tokens_total[5m])) * 100",
          "legendFormat": "Cache Hit %"
        }],
        "yaxes": [
          {"format": "percent", "min": 0, "max": 100},
          {"format": "short"}
        ]
      },
      {
        "id": 9,
        "title": "🔝 Top 5 Agents by Cost",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 12},
        "targets": [{
          "expr": "topk(5, sum by (agent_id) (increase(nevox_total_cost_cents_total[1h]))) / 100",
          "legendFormat": "Agent {{agent_id}}"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 2
          }
        }
      },
      {
        "id": 10,
        "title": "⏱️ Average Call Duration",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
        "targets": [{
          "expr": "rate(nevox_call_duration_seconds_sum[5m]) / rate(nevox_call_duration_seconds_count[5m])",
          "legendFormat": "Avg Duration"
        }],
        "yaxes": [
          {"format": "s", "label": "Seconds"},
          {"format": "short"}
        ]
      },
      {
        "id": 11,
        "title": "💬 Messages Per Call",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
        "targets": [{
          "expr": "rate(nevox_messages_per_call_sum[5m]) / rate(nevox_messages_per_call_count[5m])",
          "legendFormat": "Avg Messages"
        }],
        "yaxes": [
          {"format": "short", "label": "Messages"},
          {"format": "short"}
        ]
      },
      {
        "id": 12,
        "title": "🎤 TTS Characters (Total)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 0, "y": 28},
        "targets": [{
          "expr": "sum(nevox_tts_characters_total)",
          "legendFormat": "Characters"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0
          }
        }
      },
      {
        "id": 13,
        "title": "📝 LLM Tokens (Total)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 8, "y": 28},
        "targets": [{
          "expr": "sum(nevox_llm_prompt_tokens_total) + sum(nevox_llm_completion_tokens_total)",
          "legendFormat": "Tokens"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0
          }
        }
      },
      {
        "id": 14,
        "title": "📞 Total Calls",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 16, "y": 28},
        "targets": [{
          "expr": "sum(nevox_call_status_total)",
          "legendFormat": "Calls"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0
          }
        }
      }
    ],
    "refresh": "10s",
    "time": {"from": "now-24h", "to": "now"}
  }
}
